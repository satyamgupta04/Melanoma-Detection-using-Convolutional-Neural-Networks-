a":{}}],"source":["path = '/content/melanoma_cancer_dataset/train'\n","\n","for cat in classes:\n","    image_dir = f'{path}/{cat}'\n","    images = os.listdir(image_dir)\n","\n","    fig, ax = plt.subplots(1, 3, figsize = (15, 5))\n","    fig.suptitle(f'Images for {cat} category . . . .',\n","                 fontsize = 20)\n","\n","    for i in range(3):\n","        k = np.random.randint(0, len(images))\n","        img = np.array(Image.open(f'{path}/{cat}/{images[k]}'))\n","        ax[i].imshow(img)\n","        ax[i].axis('off')\n","    plt.show()"]},{"cell_type":"code","execution_count":9,"metadata":{"id":"BCpk0YbdVfeM","executionInfo":{"status":"ok","timestamp":1745949205589,"user_tz":-330,"elapsed":2,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["IMG_SIZE = 224\n","SPLIT = 0.2\n","EPOCHS = 10\n","BATCH_SIZE = 64"]},{"cell_type":"code","execution_count":10,"metadata":{"id":"h12dqHlYVgO6","executionInfo":{"status":"ok","timestamp":1745949211981,"user_tz":-330,"elapsed":6391,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["X = []\n","Y = []\n","\n","for i, cat in enumerate(classes):\n","  images = glob(f'{path}/{cat}/*.jpg')\n","\n","  for image in images:\n","    img = cv2.imread(image)\n","\n","    X.append(cv2.resize(img, (IMG_SIZE, IMG_SIZE)))\n","    Y.append(i)\n","\n","X = np.asarray(X)\n","one_hot_encoded_Y = pd.get_dummies(Y).values"]},{"cell_type":"code","execution_count":11,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":414,"status":"ok","timestamp":1745949212393,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"},"user_tz":-330},"id":"TQGu_tdCVjWs","outputId":"87588978-92fe-4278-8061-8616254cfaf5"},"outputs":[{"output_type":"stream","name":"stdout","text":["(7684, 224, 224, 3) (1921, 224, 224, 3)\n"]}],"source":["X_train, X_val, Y_train, Y_val = train_test_split(\n","X, one_hot_encoded_Y, test_size = SPLIT, random_state = 2022)\n","print(X_train.shape, X_val.shape)"]},{"cell_type":"markdown","metadata":{"id":"IZxnjDcsxsCv"},"source":[]},{"cell_type":"code","execution_count":11,"metadata":{"id":"wI7f_3dPxpA7","executionInfo":{"status":"ok","timestamp":1745949212395,"user_tz":-330,"elapsed":1,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":[]},{"cell_type":"code","execution_count":12,"metadata":{"id":"0yIFBZXoVlfY","executionInfo":{"status":"ok","timestamp":1745949215690,"user_tz":-330,"elapsed":3293,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["from tensorflow import keras\n","from keras.applications.densenet import DenseNet121\n","\n","pre_trained_model = DenseNet121(\n","    input_tensor=None,\n","    input_shape=None,\n","    pooling=None,\n","    classes=1000,\n","    classifier_activation=\"softmax\",\n","    name=\"densenet121\",\n",")"]},{"cell_type":"code","execution_count":13,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":20,"status":"ok","timestamp":1745949215713,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"},"user_tz":-330},"id":"A3MUwx_VVmxy","outputId":"7612ebfb-cbc5-4c4e-82fc-96d7282927cc"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["429"]},"metadata":{},"execution_count":13}],"source":["len(pre_trained_model.layers)"]},{"cell_type":"code","execution_count":14,"metadata":{"id":"mm2yR3A3VnyE","executionInfo":{"status":"ok","timestamp":1745949215716,"user_tz":-330,"elapsed":1,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["for layer in pre_trained_model.layers:\n","  layer.trainable = False"]},{"cell_type":"code","execution_count":15,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":8,"status":"ok","timestamp":1745949215725,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"},"user_tz":-330},"id":"Vjt5YuBtgRll","outputId":"60d5cfa1-c716-42c6-e311-8c80b8491c96"},"outputs":[{"output_type":"stream","name":"stdout","text":["last layer output shape:  (7, 7, 1024)\n"]}],"source":["last_layer = pre_trained_model.get_layer('relu')\n","output_shape = last_layer.input[0].shape\n","\n","print('last layer output shape: ', output_shape)\n","last_output = last_layer.output"]},{"cell_type":"code","execution_count":16,"metadata":{"id":"AwfPDWwMVrPP","executionInfo":{"status":"ok","timestamp":1745949215788,"user_tz":-330,"elapsed":52,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["x = layers.Flatten()(last_output)\n","\n","x = layers.Dense(256,activation='relu')(x)\n","x = layers.BatchNormalization()(x)\n","\n","x = layers.Dense(128,activation='relu')(x)\n","x = layers.Dropout(0.3)(x)\n","x = layers.BatchNormalization()(x)\n","\n","output = layers.Dense(2, activation='softmax')(x)\n","\n","model = keras.Model(pre_trained_model.input, output)"]},{"cell_type":"code","execution_count":17,"metadata":{"id":"stvI1oMaVstq","executionInfo":{"status":"ok","timestamp":1745949215840,"user_tz":-330,"elapsed":50,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["model.compile(\n","\toptimizer='adam',\n","\tloss='categorical_crossentropy',\n","\tmetrics=['accuracy']\n",")"]},{"cell_type":"code","execution_count":18,"metadata":{"id":"OMMJG-jsVxyT","executionInfo":{"status":"ok","timestamp":1745949215844,"user_tz":-330,"elapsed":3,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}}},"outputs":[],"source":["from keras.callbacks import EarlyStopping, ReduceLROnPlateau\n","\n","class myCallback(tf.keras.callbacks.Callback):\n","  def on_epoch_end(self, epoch, logs = {}):\n","    if logs.get('val_accuracy') > 0.95:\n","      print('\\n Validation accuracy has reached upto 90%\\\n","      so, stopping further training.')\n","      self.model.stop_training = True\n"