 _, original_Y_val = train_test_split(\n","    X, one_hot_encoded_Y, test_size=SPLIT, random_state=2022\n",")\n","\n","# Now you can use original_Y_val instead of Y_val:\n","Y_val_original = np.argmax(original_Y_val, axis=1)\n","Y_pred = np.argmax(Y_pred, axis=1)\n","\n","metrics.confusion_matrix(Y_val_original, Y_pred)"]},{"cell_type":"code","execution_count":33,"metadata":{"id":"L9gLxJKZV4dO","executionInfo":{"status":"ok","timestamp":1745949801458,"user_tz":-330,"elapsed":7,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"b9f6699a-6003-4f83-ceab-7feebe306f9f"},"outputs":[{"output_type":"execute_result","data":{"text/plain":["array([[928,  59],\n","       [ 86, 848]])"]},"metadata":{},"execution_count":33}],"source":["metrics.confusion_matrix(Y_val, Y_pred)"]},{"cell_type":"code","execution_count":34,"metadata":{"id":"vVjaiz_WV5nu","executionInfo":{"status":"ok","timestamp":1745949804141,"user_tz":-330,"elapsed":7,"user":{"displayName":"Satyam Gupta","userId":"08766549375560979426"}},"colab":{"base_uri":"https://localhost:8080/"},"outputId":"265fa137-9e70-40e9-da90-376361a7bf22"},"outputs":[{"output_type":"stream","name":"stdout","text":["              precision    recall  f1-score   support\n","\n","      benign       0.92      0.94      0.93       987\n","   malignant       0.93      0.91      0.92       934\n","\n","    accuracy                           0.92      1921\n","   macro avg       0.93      0.92      0.92      1921\n","weighted avg       0.92      0.92      0.92      1921\n","\n"]}],"source":["print(metrics.classification_report(Y_val, Y_pred,\n","\t\t\t\t\t\t\t\t\ttarget_names=classes))"]}],"metadata":{"accelerator":"GPU","colab":{"gpuType":"T4","provenance":[{"file_id":"1_DiGhYhWQPUrHalPOQgceMaFYCufgfbu","timestamp":1745902992292},{"file_id":"1aLjCPXvyPuJTeob-UTgR3Tm8weEqtzq_","timestamp":1745898592648}]},"kernelspec":{"display_name":"Python 3","name":"python3"},"langu